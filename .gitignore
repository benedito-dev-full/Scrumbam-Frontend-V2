# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Personal Agents — politica hibrida
# Commitar: STATUS.md, agent-memory, settings.json, agents/, rules/, scripts/
# Ignorar: artifacts verbose (plans, implementations, reviews)
workspace/plans/*.md
workspace/implementations/*.md
workspace/reviews/*.md
!workspace/plans/.gitkeep
!workspace/implementations/.gitkeep
!workspace/reviews/.gitkeep

# settings.local.json e local de cada dev
.claude/settings.local.json
